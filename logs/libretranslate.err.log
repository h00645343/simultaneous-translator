INFO:argostranslate.utils:('value_hypotheses:', [('дЄгЁЯр. ЩѓВщжаЁЃ ВЩПѓбаОПе§ЪНЕФЙцИёКЭДІОіКлМЃЕФЗДЪЕР§(HavelundЕШШЫ,2019Фъ;TalebЕШШЫ,2023Фъ;DeshmukhЕШШЫ,2017Фъ;Weimer & Necula,2005Фъ)ЁЃ ЮвУЧЕФЩшЖЈЦРМлСЫЬьШЛгябдАВШЋЬиадЕФЖОМСКлМЃЕФЗЂЯж,ЖјВЛЪЧвЧЦїЛЏ,здЯТЖјЩЯЕиЬНЫїЛђе§ЪНМьВщ. 6 НсТл ЮвУЧНщЩмСЫMeerkat,ЫћЪЧвЛУћВЦВњЩѓМЦЪІ,ИКд№дкВПЪ№КлМЃПтжаЗЂЯжЮЅЗДздШЛгябдАВШЋвЊЧѓЕФааЮЊЁЃ ИУЗНЗЈЭГвЛСЫВЦВњЛуБр,ДцДЂВуМйЫЕЫбЫї,ВЂЗДР§КЫВщЮЊЕЅвЛЩѓМЦб­ЛЗ,ЪфГіПЩВйзїЕФжЄОн. ЮвУЧЕФЛљзМКЭЯжЪЕЪРНчЦРМлжМдкМьбщМьВтжЪСПКЭвЕЮёаЇгУЁЃ етаЉГЩЙћЖЈЮЛДЂДцВуВЦВњЩѓМЦзїЮЊВПЪ№КѓЖдДњРэШЫЙЄжЧФмЯЕЭГНјааАВШЋМрВтЕФвЛИіЪЕМЪзщГЩВПЗжЁЃ ЕРЕТВйЪиЫЕУї БОЮФМўбаОПСЫВПЪ№ЕФДњРэЯЕЭГЕФАВШЋЩѓМЦЗНЗЈЁЃ ЫфШЛЮвУЧЕФЗНЗЈдкРыЯпИњзйЩЯдЫзї,ЕЋВПЪ№ШежОПЩвдАќКЌУєИаЕФгУЛЇКЭЯЕЭГаХЯЂ. вђДЫ,ЮвУЧМйЖЈФфУћМЧТМЁЂбЯИёЕФзМШыЙмжЦКЭХћТЖеўВп,БмУтХћТЖНЋДѓДѓдіМгРФгУЗчЯеЕФАўЯїЯИНкЁЃ', -82.53653824329376)])
